# Sovereign Portal — local development environment
#
# Copy this file to `.env`. The defaults boot a working local stack with
# email+password login and OTP printed to logs. Override only what you need.

# ---------- shared secrets (LOCAL DEV ONLY) ----------
# Replace with real random values for any non-local deployment:
#   openssl rand -hex 32
JWT_SECRET=dev-only-not-for-production
INTERNAL_S2S_SECRET=dev-only-not-for-production
EVENT_INBOUND_SECRET=dev-only-not-for-production

# ---------- session cookie ----------
SESSION_COOKIE_NAME=sovereign_session

# ---------- bootstrap operator (first-boot seed) ----------
# These are the credentials for the first user. Email+password login works
# out of the box. The phone is used by the OTP path (which is bypassed in
# dev — see DEV_OTP_BYPASS below).
SEED_OPERATOR_EMAIL=operator@sovereign.local
SEED_OPERATOR_PASSWORD=sovereign-portal-admin
SEED_OPERATOR_PHONE=+15555550199
SEED_OPERATOR_FIRST_NAME=Portal
SEED_OPERATOR_LAST_NAME=Operator

# ---------- OTP delivery ----------
# Leave DEV_OTP_BYPASS=1 for local dev — any phone OTP login will accept the
# bypass code below. To switch to real SMS, set Twilio credentials below and
# remove DEV_OTP_BYPASS.
DEV_OTP_BYPASS_CODE=424242
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ---------- email delivery (optional) ----------
# The foundation does not ship a comms module. Email invites are no-ops
# unless you point COMMS_URL at a transactional service that implements the
# /v1/send contract documented in docs/smi-spec.md.
COMMS_URL=
COMMS_SHARED_SECRET=

# ---------- password hashing ----------
BCRYPT_ROUNDS=10
