# Sovereign Portal — local development environment
#
# Copy this file to `.env` and edit as needed. The defaults boot a working
# local stack with mocked external services (OTP printed to logs, mock LLM).
# Override only what you need.

# ---------- shared secrets (LOCAL DEV ONLY) ----------
# These are dev-only placeholders. For any non-local deployment, replace with
# real random strings (`openssl rand -hex 32`) and store in a secret manager.
SERVICE_PRINCIPAL_SECRET=dev-only-not-for-production
USER_JWT_SECRET=dev-only-not-for-production

# ---------- Users module: OTP / auth provider ----------
# 'console' prints OTP codes to the users-be logs (default for local dev).
# Set to 'twilio' and fill the SID/token/verify-SID below for real SMS.
OTP_PROVIDER=console
TWILIO_ACCOUNT_SID=dev-mock
TWILIO_AUTH_TOKEN=dev-mock
TWILIO_VERIFY_SID=dev-mock

# ---------- Customer Support agent: LLM provider ----------
# 'mock' uses the bundled heuristic fallback (no API calls, ships with the
# template). Set to 'openai' or 'anthropic' and provide a key to use a real
# model for the agent's classify + draft-reply capabilities.
LLM_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
